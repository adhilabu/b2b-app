# =============================================================================
# DSD B2B SaaS — Environment Variables Template
# Copy to .env and fill in your values
# =============================================================================

# ─────────────────────────────────────────────
# SHARED
# ─────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# JWT (RS256) — Generate with: scripts/gen_keys.sh
# ─────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./infra/keys/private.pem
JWT_PUBLIC_KEY_PATH=./infra/keys/public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# ─────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=b2b_admin
POSTGRES_PASSWORD=change_me_in_production

# Per-service databases (auto-created by init.sql)
IDENTITY_DB_NAME=identity_db
CATALOG_DB_NAME=catalog_db
SALES_DB_NAME=sales_db
ROUTE_DB_NAME=route_db
ATTENDANCE_DB_NAME=attendance_db
NOTIFICATION_DB_NAME=notification_db

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────
# APACHE PULSAR
# ─────────────────────────────────────────────
PULSAR_SERVICE_URL=pulsar://pulsar:6650
PULSAR_ADMIN_URL=http://pulsar:8080

# ─────────────────────────────────────────────
# SERVICE INTERNAL URLS (used by orchestration)
# ─────────────────────────────────────────────
IDENTITY_SERVICE_URL=http://identity:8001
CATALOG_SERVICE_URL=http://catalog:8002
SALES_SERVICE_URL=http://sales:8003
ROUTE_SERVICE_URL=http://route:8004
ATTENDANCE_SERVICE_URL=http://attendance:8005
NOTIFICATION_SERVICE_URL=http://notification:8006

# ─────────────────────────────────────────────
# FIREBASE (Notification Service)
# ─────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./infra/keys/firebase-service-account.json

# ─────────────────────────────────────────────
# WEB PUSH / VAPID (Notification Service)
# ─────────────────────────────────────────────
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_CLAIMS_EMAIL=admin@yourdomain.com

# ─────────────────────────────────────────────
# EMAIL (Notification Service)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────
# ORCHESTRATION SERVICE
# ─────────────────────────────────────────────
ORCHESTRATION_PORT=8000
ORCHESTRATION_SERVICE_SECRET=internal_service_secret_change_me

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
